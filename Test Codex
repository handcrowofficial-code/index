    <script>  
        // আপনার কনসোলের অফিশিয়াল ক্লায়েন্ট আইডি
        const CLIENT_ID = "787007794338-ncemnu36u3f1cb66g8k2hgrb5s90hshk.apps.googleusercontent.com";
        
        // কনসোলে অনুমোদিত রিডাইরেক্ট ইউআরএল (হুবহু এক)
        const REDIRECT_URI = "https://handcrow.github.io"; 

        function loginWithGoogle() {
            if(localStorage.getItem('user_logged_in')) return;

            // prompt=select_account দেওয়ার কারণে ইউজারকে প্রতিবার নিজের নতুন ইমেইল ও পাসওয়ার্ড লেখার সুযোগ দেওয়া হবে
            const googleAuthUrl = "https://accounts.google.com/o/oauth2/v2/auth?" + 
                "client_id=" + CLIENT_ID +
                "&redirect_uri=" + encodeURIComponent(REDIRECT_URI) +
                "&response_type=token" +
                "&scope=" + encodeURIComponent("https://www.googleapis.com/auth/userinfo.profile https://www.googleapis.com/auth/userinfo.email") +
                "&prompt=select_account" + 
                "&include_granted_scopes=true";
            
            window.location.href = googleAuthUrl;
        }

        function checkGoogleResponse() {
            const hash = window.location.hash;
            if (hash) {
                const params = new URLSearchParams(hash.substring(1));
                const accessToken = params.get("access_token");

                if (accessToken) {
                    fetch("https://www.googleapis.com/oauth2/v3/userinfo", {
                        headers: { "Authorization": `Bearer ${accessToken}` }
                    })
                    .then(res => res.json())
                    .then(data => {
                        // ইউজারের রিয়েল নাম ও ছবি সেভ করা
                        localStorage.setItem('user_name', data.given_name || data.name);
                        localStorage.setItem('user_pic', data.picture);
                        localStorage.setItem('user_logged_in', true);
                        
                        // এড্রেস বার থেকে টোকেন ক্লিন করা
                        window.history.replaceState({}, document.title, window.location.pathname);
                        updateProfileUI(localStorage.getItem('user_name'), localStorage.getItem('user_pic'));
                    })
                    .catch(err => console.log("Error fetching user data:", err));
                }
            } else {
                if(localStorage.getItem('user_logged_in')) {
                    updateProfileUI(localStorage.getItem('user_name'), localStorage.getItem('user_pic'));
                }
            }
        }

        function updateProfileUI(name, picUrl) {
            document.getElementById('userDisplay').innerText = "Hi, " + name;
            document.getElementById('profilePic').innerHTML = `<img src="${picUrl}" alt="User" style="width:100%; height:100%; object-fit:cover;">`;
            document.getElementById('profileArea').style.cursor = "default";
        }

        window.onload = function() {
            showP('p1');
            checkGoogleResponse();
        };

        // সাইট নেভিগেশন ও বাকি সব সাধারণ ফিচারসমূহ
        function showP(id) { document.querySelectorAll('.page').forEach(p => p.classList.remove('active')); const page = document.getElementById(id); if (page) page.classList.add('active'); if (id === 'solar-page') loadSolarCards(); }  
        function togglePanel(isOpen) { const panel = document.getElementById('sidePanel'); const overlay = document.getElementById('panelOverlay'); if(isOpen) { panel.classList.add('open'); overlay.classList.add('active'); } else { panel.classList.remove('open'); overlay.classList.remove('active'); } }
        function sendSecretMail() { const msg = document.getElementById('secretMsg').value.trim(); if (!msg) return alert("বার্তা লিখুন!"); window.location.href = `mailto:ayanraj1483@gmail.com?subject=Secret Message&body=${encodeURIComponent(msg)}`; }  
        function openYouTube(channel) { if (channel === 'eren') window.open('https://www.youtube.com/@eren_amv_xd', '_blank'); else if (channel === 'season') window.open('https://www.youtube.com/@seasongamerzbd', '_blank'); }  
        function clearSearch() { document.getElementById('searchInput').value = ""; document.getElementById('searchArea').style.display = "none"; document.getElementById('homeGrid').style.display = "grid"; }  
        
        async function executeAdvancedSearch() {  
            let input = document.getElementById('searchInput').value.trim(); if (!input) return alert("কিছু লিখুন!");  
            const searchArea = document.getElementById('searchArea'); const homeGrid = document.getElementById('homeGrid'); const resultsBox = document.getElementById('webResults'); const statusText = document.getElementById('searchStatus'); const loader = document.getElementById('loader');  
            homeGrid.style.display = "none"; searchArea.style.display = "block"; resultsBox.innerHTML = ""; loader.style.display = "block"; statusText.innerText = `"${input}" এর জন্য সার্চ চলছে...`;  
            if (input.toLowerCase().includes("black")) { loader.style.display = "none"; statusText.innerText = `"${input}" এর ফলাফল`; resultsBox.innerHTML = `<div class="web-result-item" onclick="window.open('https://drive.google.com/file/d/1RYEMdH5Blv3VVMzZMBqM7dqjmYftTcY_/view?usp=drivesdk', '_blank')" style="border: 2px solid #BF953F; background: rgba(191, 149, 63, 0.15);"><span style="color:#ff3131; font-size:0.85rem; font-weight:700;">🔓 SPECIAL ACCESS</span><h4 style="margin:10px 0 8px; color:#FCF6BA; font-size:1.35rem;">OPEN BLACK</h4><p style="margin:0; font-size:1rem; color:#fff;">Click here to open the secret Black file</p></div>`; return; }  
            loader.style.display = "none"; statusText.innerText = "কোনো ফলাফল পাওয়া যায়নি (ডেমো)";  
        }  

        const solarBodies = [ { name: "সূর্য (Sun)", image: "https://upload.wikimedia.org/wikipedia/commons/b/b4/The_Sun_by_the_Atmospheric_Imaging_Assembly_of_NASA%27s_Solar_Dynamics_Observatory_-_20100819.jpg", details: "সূর্য আমাদের সৌরজগতের কেন্দ্রীয় তারকা।" }, { name: "বুধ (Mercury)", image: "https://upload.wikimedia.org/wikipedia/commons/3/30/Mercury_in_color_-_Prockter07_centered.jpg", details: "সূর্যের সবচেয়ে কাছের গ্রহ।" }, { name: "শুক্র (Venus)", image: "https://upload.wikimedia.org/wikipedia/commons/e/e5/Venus-real_color.jpg", details: "পৃথিবীর যমজ গ্রহ।" }, { name: "পৃথিবী (Earth)", image: "https://upload.wikimedia.org/wikipedia/commons/c/cb/The_Blue_Marble_%28remastered%29.jpg", details: "আমাদের বাসস্থান।" }, { name: "মঙ্গল (Mars)", image: "https://upload.wikimedia.org/wikipedia/commons/0/02/OSIRIS_Mars_true_color.jpg", details: "লাল গ্রহ।" }, { name: "বৃহস্পতি (Jupiter)", image: "https://upload.wikimedia.org/wikipedia/commons/2/2b/Jupiter_and_its_shrunken_Great_Red_Spot.jpg", details: "সবচেয়ে বড় গ্রহ।" }, { name: "শনি (Saturn)", image: "https://upload.wikimedia.org/wikipedia/commons/c/c7/Saturn_during_Equinox.jpg", details: "রিংসের জন্য বিখ্যাত।" } ];  
        function loadSolarCards() { const container = document.getElementById('planetGrid'); container.innerHTML = ''; solarBodies.forEach(body => { const card = document.createElement('div'); card.className = 'planet-card'; card.innerHTML = `<img src="${body.image}" alt="${body.name}"><h3>${body.name}</h3>`; card.onclick = () => showPlanetInfo(body); container.appendChild(card); }); }  
        function showPlanetInfo(body) { document.getElementById('infoTitle').textContent = body.name; document.getElementById('infoDetails').innerHTML = `<p>${body.details}</p>`; document.getElementById('infoImageContainer').innerHTML = `<img src="${body.image}" style="max-height:380px; border-radius:15px; max-width:100%; object-fit:cover;">`; document.getElementById('planetInfoPanel').classList.add('active'); }  
        function closePlanetInfo() { document.getElementById('planetInfoPanel').classList.remove('active'); }  
        function speakPlanetInfo() { const title = document.getElementById('infoTitle').textContent; const details = document.getElementById('infoDetails').textContent; if ('speechSynthesis' in window) { const utterance = new SpeechSynthesisUtterance(`${title}। ${details}`); utterance.lang = 'bn-BD'; speechSynthesis.speak(utterance); } }  
        document.getElementById("searchInput").addEventListener("keypress", (e) => { if (e.key === "Enter") executeAdvancedSearch(); });  
    </script>  
</body>  
</html>

