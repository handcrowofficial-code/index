<!DOCTYPE html>  
<html lang="bn">  
<head>  
    <meta charset="UTF-8">  
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>• Handcrow Official | 2026 Premium •</title>  
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght=300;400;600;700&family=Montserrat:wght=700;900&display=swap" rel="stylesheet">  
    
    <style>  
        :root {  
            --gold-gradient: linear-gradient(45deg, #BF953F, #FCF6BA, #B38728, #FBF5B7, #AA771C);  
            --deep-dark: #010409;  
            --glass: rgba(255, 255, 255, 0.02);  
            --glass-border: rgba(255, 255, 255, 0.08);  
            --live-red: #ff3131;  
        }  
        
        body {  
            font-family: 'Montserrat', 'Hind Siliguri', sans-serif;  
            margin: 0;   
            background: var(--deep-dark);   
            color: #f8fafc;  
            overflow-x: hidden;   
            scroll-behavior: smooth;  
        }  

        .page {   
            display: none;   
            min-height: 100vh;   
            padding-bottom: 120px;   
            opacity: 0;   
        }  
        .active {   
            display: block;   
            animation: pageIn 0.8s ease-out forwards;   
        }  
        @keyframes pageIn {  
            0% { opacity: 0; transform: translateY(30px); filter: blur(10px); }  
            100% { opacity: 1; transform: translateY(0); filter: blur(0); }  
        }  

        .luxury-text {  
            background: var(--gold-gradient);  
            -webkit-background-clip: text;  
            -webkit-text-fill-color: transparent;  
            font-weight: 900;  
        }  

        /* Header Control Panel */
        .header-controls {
            position: fixed;
            top: 20px;
            left: 20px;
            right: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1001;
        }

        .menu-burger-btn {
            background: var(--glass);
            border: 1px solid #BF953F;
            color: #FCF6BA;
            padding: 12px 18px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 700;
            font-size: 1rem;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .menu-burger-btn:hover {
            background: rgba(191, 149, 63, 0.2);
            box-shadow: 0 0 15px rgba(191, 149, 63, 0.3);
        }

        .profile-container {   
            cursor: pointer;   
            text-align: right;   
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.03);
            padding: 6px 16px;
            border-radius: 30px;
            border: 1px solid #BF953F;
            transition: 0.3s;
        }  

        .profile-pic {   
            width: 35px;   
            height: 35px;   
            border-radius: 50%;   
            border: 1px solid #FCF6BA;   
            background: #111;   
            display: flex;   
            align-items: center;   
            justify-content: center;   
            font-size: 1rem;   
            overflow: hidden;
        }  
        .profile-pic img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Side Panel */
        .side-panel {
            position: fixed;
            top: 0;
            left: -350px;
            width: 310px;
            height: 100vh;
            background: rgba(1, 4, 9, 0.95);
            backdrop-filter: blur(20px);
            border-right: 1px solid #BF953F;
            box-shadow: 5px 0 30px rgba(0,0,0,0.8);
            z-index: 2000;
            transition: 0.5s cubic-bezier(0.77,0.2,0.05,1.0);
            padding: 30px 20px;
            box-sizing: border-box;
        }
        .side-panel.open { left: 0; }
        .panel-close-btn { background: transparent; border: none; color: #ff3131; font-size: 1.8rem; cursor: pointer; float: right; }
        .panel-title { margin-top: 40px; font-size: 1.5rem; border-bottom: 1px solid var(--glass-border); padding-bottom: 15px; }

        .panel-list { margin-top: 30px; display: flex; flex-direction: column; gap: 15px; }
        .panel-list-item { display: flex; align-items: center; gap: 15px; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--glass-border); padding: 12px; border-radius: 15px; cursor: pointer; transition: 0.3s; text-decoration: none; color: #fff; }
        .panel-list-item:hover { border-color: #BF953F; background: rgba(191, 149, 63, 0.12); transform: translateX(5px); }
        
        .panel-squares-icon { width: 50px; height: 50px; border-radius: 10px; border: 1px solid #FCF6BA; background: rgba(191, 149, 63, 0.1); display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 5px; padding: 8px; box-sizing: border-box; }
        .panel-squares-icon div { background: var(--gold-gradient); border-radius: 3px; }
        .panel-item-img { width: 50px; height: 50px; border-radius: 10px; object-fit: cover; border: 1px solid #FCF6BA; }
        .panel-item-info h4 { margin: 0 0 5px 0; color: #FCF6BA; font-size: 1rem; }
        .panel-item-info p { margin: 0; font-size: 0.75rem; color: #cbd5e1; }

        .panel-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1999; display: none; }
        .panel-overlay.active { display: block; }

        .live-dot-pulse { width: 10px; height: 10px; background: var(--live-red); border-radius: 50%; display: inline-block; margin-right: 8px; animation: pulse-red 1.2s infinite; vertical-align: middle; }  
        @keyframes pulse-red { 0% { transform: scale(0.9); box-shadow: 0 0 0 0 rgba(255, 49, 49, 0.7); } 70% { transform: scale(1.2); box-shadow: 0 0 0 8px rgba(255, 49, 49, 0); } 100% { transform: scale(0.9); box-shadow: 0 0 0 0 rgba(255, 49, 49, 0); } }  

        .search-box-wrapper { max-width: 500px; margin: 25px auto; display: flex; gap: 10px; padding: 0 20px; }  
        .search-input { flex: 1; padding: 14px 20px; border-radius: 25px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.05); color: #fff; outline: none; font-size: 1.05rem; }  
        .search-btn { background: var(--gold-gradient); border: none; width: 52px; height: 52px; border-radius: 50%; cursor: pointer; font-size: 1.4rem; }  

        .search-results-area { display: none; max-width: 800px; margin: 20px auto; padding: 0 20px; }  
        .web-result-item { background: rgba(255, 255, 255, 0.03); border: 1px solid var(--glass-border); padding: 20px; border-radius: 20px; margin-bottom: 15px; cursor: pointer; transition: 0.3s; }  
        .web-result-item:hover { border-color: #BF953F; background: rgba(191,149,63,0.05); }  

        .loader { display: none; width: 32px; height: 32px; border: 4px solid #f3f3f3; border-top: 4px solid #BF953F; border-radius: 50%; animation: spin 1s linear infinite; margin: 25px auto; }  
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }  

        .home-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; padding: 30px 20px; max-width: 1000px; margin: 0 auto; }  
        .card { background: var(--glass); border: 1px solid var(--glass-border); padding: 30px; border-radius: 30px; transition: 0.4s; cursor: pointer; }  
        .card:hover { transform: translateY(-10px); border-color: #BF953F; background: rgba(191,149,63,0.08); }  

        .btn-nav { padding: 10px 22px; border-radius: 50px; border: 1px solid #BF953F; background: transparent; color: #FCF6BA; cursor: pointer; font-weight: 700; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; margin: 5px; }  
        .active-btn { background: var(--gold-gradient); color: #000; }  
          
        .news-list { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 25px; padding: 15px; }  
        .news-item { padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }  

        .secret-footer { position: fixed; bottom: 0; left: 0; width: 100%; padding: 20px; text-align: center; background: rgba(1, 4, 9, 0.98); color: #BF953F; font-weight: 700; cursor: pointer; border-top: 1px solid var(--glass-border); z-index: 1000; }  

        .youtube-section { max-width: 1000px; margin: 40px auto; padding: 0 20px; }  
        .youtube-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 25px; }  
        .yt-card { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 25px; padding: 25px 20px; text-align: center; transition: all 0.4s; cursor: pointer; }  
        .yt-card:hover { transform: translateY(-12px); border-color: #BF953F; background: rgba(191,149,63,0.1); }  
        .yt-icon { font-size: 4.5rem; margin-bottom: 15px; }  
        .yt-btn { background: var(--gold-gradient); color: #000; border: none; padding: 12px 35px; border-radius: 50px; font-weight: 700; cursor: pointer; }  

        .solar-container { max-width: 1100px; margin: 30px auto; padding: 0 20px; display: flex; flex-wrap: wrap; gap: 25px; justify-content: center; }  
        .planet-card { background: rgba(255,255,255,0.05); border: 1px solid #BF953F; border-radius: 20px; width: 180px; text-align: center; padding: 15px; cursor: pointer; transition: 0.4s; }  
        .planet-card:hover { transform: scale(1.08); background: rgba(191, 149, 63, 0.15); }  
        .planet-card img { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid #FCF6BA; }  

        .planet-info-panel { max-width: 820px; margin: 30px auto; padding: 30px; background: var(--glass); border: 1px solid var(--glass-border); border-radius: 25px; display: none; }  
        .planet-info-panel.active { display: block; }  
        .listen-btn { background: var(--gold-gradient); color: #000; border: none; padding: 12px 30px; border-radius: 50px; font-weight: 700; cursor: pointer; margin-top: 15px; font-size: 1.05rem; }  
        .branding-container { display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 10px; }
        .official-box { border: 1px solid #BF953F; padding: 3px 10px; border-radius: 5px; font-size: 0.8rem; color: #FCF6BA; }
    </style>
</head>  
